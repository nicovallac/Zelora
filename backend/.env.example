DATABASE_URL=postgresql://comfa_user:comfa_pass@db:5432/comfaguajira
SECRET_KEY=change-me-to-a-random-32-char-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REDIS_URL=redis://redis:6379/0
ENVIRONMENT=development

# WhatsApp Cloud API (Meta Business)
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE
WHATSAPP_ACCESS_TOKEN=YOUR_PERMANENT_ACCESS_TOKEN_HERE
WHATSAPP_VERIFY_TOKEN=comfaguajira_verify_2026

# When empty, the system runs in simulation mode (no real WhatsApp messages sent)
# For local testing with ngrok: set webhook URL to https://YOUR_NGROK_URL/whatsapp/webhook
