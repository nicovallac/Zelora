# ─── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
DB_NAME=vendly_db
DB_USER=vendly_user
DB_PASSWORD=supersecurepassword
DB_HOST=postgres
DB_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=vendly-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── WhatsApp / Meta ───────────────────────────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_VERSION=v19.0
WHATSAPP_BASE_URL=https://graph.facebook.com

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.vendly.ai
CORS_ALLOWED_ORIGINS=https://app.vendly.ai,https://vendly.ai

# ─── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=no-reply@vendly.ai

# ─── Field Encryption ──────────────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY=your-32-byte-fernet-key-base64-encoded==
