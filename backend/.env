SECRET_KEY=comfaguajira-poc-secret-key-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REDIS_URL=redis://redis:6379/0
ENVIRONMENT=development

# WhatsApp Cloud API (Meta Business)
